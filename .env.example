# ============================================================
# CFaceAI — Environment Variables Example
# Copy the relevant section to each service's .env file
# ============================================================

# ------------------------------------------------------------
# backend/.env
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tlg_web
# (SQLite fallback for local dev)
# DATABASE_URL=sqlite:///./tlg_web.db

JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

TELEGRAM_BOT_TOKEN=123456789:AAH_your_real_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# URL of the frontend (used for CORS)
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------
# telegram-bot/.env
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:AAH_your_real_bot_token_here

# Base URL of the backend API (no trailing slash)
BACKEND_API_URL=http://localhost:8000

# Used by handlers/leave.py for leave approval callbacks
BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------
# frontend/.env  (Vite — must be prefixed with VITE_)
# ------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
